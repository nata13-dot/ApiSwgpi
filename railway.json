{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKER"
  },
  "deploy": {
    "startCommand": "php artisan migrate --force && php-fpm -D && nginx -g 'daemon off;'",
    "restartPolicyMaxRetries": 5,
    "healthchecks": {
      "readiness": {
        "httpPath": "/health",
        "initialDelaySeconds": 10
      },
      "liveness": {
        "httpPath": "/health",
        "initialDelaySeconds": 30
      }
    }
  }
}
